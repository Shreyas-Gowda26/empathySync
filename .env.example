# empathySync Configuration
# Copy this file to .env and configure your settings

# ===================
# Required: Ollama
# ===================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TEMPERATURE=0.7

# ===================
# Optional: Database
# ===================
# Only needed if you want PostgreSQL storage (not required for basic usage)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=empathysync
# DB_USER=
# DB_PASSWORD=

# ===================
# Application
# ===================
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ===================
# Privacy Settings
# ===================
STORE_CONVERSATIONS=true
CONVERSATION_RETENTION_DAYS=30

# ===================
# Classification
# ===================
# Enable LLM-based intelligent classification (Phase 9)
# When true, uses the Ollama model for context-aware domain detection
# When false, falls back to keyword-only matching
LLM_CLASSIFICATION_ENABLED=true

# ===================
# Storage Backend
# ===================
# Use SQLite instead of JSON files for data storage
# SQLite offers better concurrency, transactions, and crash safety (WAL mode)
# Default: false (uses JSON files in data/ directory)
USE_SQLITE=false

# ===================
# Multi-Device Sync
# ===================
# Enable heartbeat-based lock file for multi-device sync safety
# When enabled, only one device can write data at a time
# Other devices enter read-only mode until the lock is released
# Default: false (single device, no locking needed)
ENABLE_DEVICE_LOCK=false

# Seconds until a lock from another device is considered stale
# If the other device crashes or loses power, the lock expires after this timeout
# Default: 300 (5 minutes)
LOCK_STALE_TIMEOUT=300
